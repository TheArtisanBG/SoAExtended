IF
    Global("C0X1MariaQuest","GLOBAL",9)
    InMyArea("MARIA")
    InMyArea("KELDORN")
THEN
RESPONSE #100
ActionOverride("MARIA",StartDialogNoSet("KELDORN"))
Continue()
END

IF
    Global("C0X1MariaQuest","GLOBAL",12)
    GlobalTimerExpired("C0X1MariaQuestSkip","GLOBAL")
THEN
RESPONSE #100
    SetGlobal("C0X1MariaQuest","GLOBAL",13)
    MoveGlobal("AR1003","KELDORN",[648.460])
    Continue()
END
